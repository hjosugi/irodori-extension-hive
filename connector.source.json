{
  "schemaVersion": 1,
  "extensionId": "irodori.hive",
  "visibility": "public",
  "version": "0.1.0",
  "connector": {
    "id": "hive.connector",
    "engine": "hive",
    "label": "Hive",
    "aliases": [
      "hive",
      "Apache Hive",
      "Hive"
    ],
    "defaultPort": 10000,
    "wire": "jdbc",
    "module": "hive.driver",
    "features": [
      "metadata",
      "sql"
    ]
  },
  "connection": {
    "endpoint": {
      "modes": [
        "catalog",
        "objectStorage",
        "jdbc",
        "connectionString"
      ],
      "defaultPort": 10000,
      "fields": [
        {
          "id": "catalogUri",
          "label": "Catalog URI",
          "type": "uri",
          "option": "catalogUri"
        },
        {
          "id": "warehouse",
          "label": "Warehouse path",
          "type": "string",
          "option": "warehouse"
        }
      ]
    },
    "authMethods": [
      "none",
      "connectionString",
      "userPassword",
      "basic",
      "bearerToken",
      "oauth2",
      "kerberos",
      "ldap",
      "clientCertificate",
      "customDriverOptions"
    ],
    "tls": "optional",
    "transports": "default",
    "optionNamespaces": [
      "jdbc",
      "hive"
    ],
    "customDriverOptions": true
  },
  "runtime": {
    "driverLinked": false
  },
  "source": {
    "knowledgeEngineStatus": "recognized_no_connector",
    "adapter": null
  }
}
